// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

enum AppointmentStatus {
  PENDING
  CONFIRMED
  CHECKED_IN
  IN_PROGRESS
  COMPLETED
  CANCELLED
  RESCHEDULED
}

enum HealthCondition {
  WELLNESS_CHECK // Kiểm tra sức khỏe tổng quát
  HYPERTENSION // Cao huyết áp
  PHYSIOTHERAPY // Vật lý trị liệu
  POST_OP_RECOV // Hồi phục sau phẫu thuật
}

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id             String          @id @default(uuid())
  email          String          @unique
  password       String
  patientProfile PatientProfile?
  firstName      String?
  lastName       String?
  role           String          @default("PATIENT")
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  appointments   Appointment[]

  @@map("users")
}

model Doctor {
  id           String        @id @default(uuid())
  name         String
  specialty    String
  experience   String
  image        String?
  rating       Float?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  appointments Appointment[]

  @@map("doctors")
}

model ServiceType {
  id           String        @id @default(uuid())
  title        String
  description  String
  icon         String?
  price        Float?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  appointments Appointment[]

  @@map("service_types")
}

model News {
  id        String   @id @default(uuid())
  title     String
  subtitle  String?
  category  String
  date      String
  image     String?
  author    String
  readTime  String?
  featured  Boolean  @default(false)
  summary   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("news")
}

model TimeSlot {
  id        String   @id @default(uuid())
  time      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("time_slots")
}

model Appointment {
  id            String            @id @default(uuid())
  doctorId      String
  doctor        Doctor            @relation(fields: [doctorId], references: [id])
  serviceTypeId String
  serviceType   ServiceType       @relation(fields: [serviceTypeId], references: [id])
  timeSlot      String
  date          String
  patientId     Int               @default(0)
  patient       PatientProfile    @relation(fields: [patientId], references: [id])
  patientName   String
  patientPhone  String
  reason        String
  userId        String?
  user          User?             @relation(fields: [userId], references: [id])
  status        AppointmentStatus @default(PENDING)
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  @@map("appointments")
}

model PatientProfile {
  id             Int              @id @default(autoincrement())
  userId         String           @unique // Liên kết 1-1 với tài khoản người dùng
  user           User             @relation(fields: [userId], references: [id])
  condition      HealthCondition? @default(WELLNESS_CHECK)
  birthday       DateTime?
  gender         String?
  bloodType      String?
  address        String?
  medicalHistory String?          @db.Text
  allergies      String?          @db.Text

  // Quan hệ với các cuộc hẹn để lấy lịch sử
  appointments Appointment[]

  // Lưu trữ file kết quả (link từ S3/Cloudinary)
  documents MedicalDocument[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("patient_profiles")
}

model MedicalDocument {
  id               Int            @id @default(autoincrement())
  patientProfileId Int
  patient          PatientProfile @relation(fields: [patientProfileId], references: [id])
  fileUrl          String
  fileName         String
  fileType         String // Ví dụ: "X-RAY", "PRESCRIPTION", "LAB_RESULT"
  createdAt        DateTime       @default(now())

  @@map("medical_documents")
}
